# Базовый образ: официальный Python 3.11 на минимальном Linux (Alpine)
# Alpine весит ~50MB против ~900MB у обычного debian — идеально для бота
FROM python:3.11-slim

# Устанавливаем рабочую директорию внутри контейнера
# Все следующие команды будут выполняться отсюда
WORKDIR /app

# Устанавливаем uv — наш менеджер пакетов
# Делаем это до копирования кода, чтобы Docker кэшировал этот слой
RUN pip install uv --no-cache-dir

# Копируем только файлы зависимостей — сначала их
# Docker кэширует слои: если зависимости не менялись,
# этот шаг не будет повторяться при пересборке
COPY pyproject.toml uv.lock ./

# Устанавливаем зависимости без dev-пакетов
RUN uv sync --frozen --no-dev

# Копируем весь остальной код проекта
COPY . .

# Создаём папку для базы данных
# Она будет монтироваться снаружи (volume), но папка должна существовать
RUN mkdir -p /app/data

# Команда запуска бота
# uv run — запускает в контексте виртуального окружения
CMD ["uv", "run", "python", "bot.py"]
