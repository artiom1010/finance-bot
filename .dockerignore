# Виртуальное окружение — пересоздаётся внутри контейнера
.venv/

# Секреты — передаются через переменные окружения, не файл
.env

# База данных — монтируется как volume снаружи
*.db

# Git и инструменты
.git/
.gitignore
.claude/
.vscode/

# Python
__pycache__/
*.pyc

# Учебные материалы
PDP/

# Mac
.DS_Store
